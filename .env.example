# Copy this file to ".env" and fill in your real values.
# The app reads these via config.py using python-dotenv.

# Get a FREE key (no credit card required) from Google AI Studio:
# https://aistudio.google.com/apikey
# If left blank, the app automatically runs in MOCK MODE (fixed demo
# sensor data) so you can still build/test the UI without any key.
GEMINI_API_KEY=

# Model used for document extraction. gemini-2.5-flash is the safest
# default: consistently on Google's free tier with generous limits.
# Check https://ai.google.dev/gemini-api/docs/rate-limits for the
# current live numbers before a demo -- Google has changed free-tier
# limits/model eligibility multiple times through 2025-2026.
GEMINI_MODEL=gemini-2.5-flash

# Any random string -- used to sign Flask session cookies.
FLASK_SECRET_KEY=change-this-to-a-random-string
